{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "linux-debug",
      "displayName": "Linux Debug (system packages)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SOUNDSHELF_BUILD_TESTS": "ON"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release (system packages)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SOUNDSHELF_BUILD_TESTS": "ON"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" }
    },
    {
      "name": "windows-msys2",
      "displayName": "Windows MinGW64 (MSYS2 packages)",
      "description": "Legacy path — MSYS2 provides all deps via pacman.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SOUNDSHELF_BUILD_TESTS": "ON"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    },
    {
      "name": "windows-vcpkg",
      "displayName": "Windows MSVC + vcpkg (recommended)",
      "description": "vcpkg provides C/C++ libs statically; Qt from aqtinstall; libmpv pre-built.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-vcpkg",
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "SOUNDSHELF_BUILD_TESTS": "ON",
        "SOUNDSHELF_ENABLE_LIBCDIO": "OFF",
        "MPV_DIR": "${sourceDir}/external/mpv-dev"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    },
    {
      "name": "windows-msys2",
      "configurePreset": "windows-msys2"
    },
    {
      "name": "windows-vcpkg",
      "configurePreset": "windows-vcpkg"
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-vcpkg",
      "configurePreset": "windows-vcpkg",
      "output": { "outputOnFailure": true }
    }
  ]
}
